{
  "name": "docsai",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "license": "Apache-2.0",
  "packageManager": "pnpm@11.5.0",
  "scripts": {
    "dev": "next dev -H 127.0.0.1",
    "build": "next build && pnpm deploy:standalone",
    "start": "next start -H 127.0.0.1",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:studio": "drizzle-kit studio --host 127.0.0.1",
    "worker": "tsx src/workers/index.ts",
    "audit": "pnpm audit --audit-level moderate",
    "deploy:standalone": "rm -rf .next/standalone/.next/static .next/standalone/public && mkdir -p .next/standalone/.next && cp -R .next/static .next/standalone/.next/static && cp -R public .next/standalone/public"
  },
  "dependencies": {
    "@ai-sdk/openai": "3.0.67",
    "@ai-sdk/react": "3.0.195",
    "@llamaindex/liteparse": "2.0.3",
    "@radix-ui/react-use-controllable-state": "^1.2.2",
    "@rive-app/react-webgl2": "^4.28.6",
    "@streamdown/cjk": "^1.0.3",
    "@streamdown/code": "^1.1.1",
    "@streamdown/math": "^1.0.2",
    "@streamdown/mermaid": "^1.0.2",
    "@xyflow/react": "^12.10.2",
    "ai": "6.0.193",
    "ansi-to-react": "^6.2.6",
    "better-auth": "1.6.12",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "cmdk": "^1.1.1",
    "drizzle-orm": "0.45.2",
    "embla-carousel-react": "^8.6.0",
    "file-type": "22.0.1",
    "graphile-worker": "0.16.6",
    "kysely": "0.28.17",
    "lucide-react": "1.17.0",
    "media-chrome": "^4.19.0",
    "motion": "^12.40.0",
    "nanoid": "5.1.11",
    "next": "16.2.6",
    "pg": "8.21.0",
    "pino": "10.3.1",
    "radix-ui": "^1.4.3",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-hook-form": "7.76.1",
    "react-jsx-parser": "^2.4.1",
    "shiki": "^4.1.0",
    "streamdown": "2.5.0",
    "tailwind-merge": "3.6.0",
    "tokenlens": "^1.3.1",
    "tw-animate-css": "1.4.0",
    "use-stick-to-bottom": "^1.1.4",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "1.60.0",
    "@tailwindcss/postcss": "4.3.0",
    "@types/node": "25.9.1",
    "@types/pg": "8.20.0",
    "@types/react": "19.2.15",
    "@types/react-dom": "19.2.3",
    "drizzle-kit": "0.31.10",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.6",
    "tailwindcss": "4.3.0",
    "tsx": "4.22.3",
    "typescript": "6.0.3",
    "vitest": "4.1.7"
  },
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=11.0.0"
  }
}
