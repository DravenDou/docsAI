# App base URL. Keep local-only while developing on the VPS.
BETTER_AUTH_URL=http://127.0.0.1:3000
BETTER_AUTH_SECRET=change-me-to-a-random-32-plus-char-secret

# PostgreSQL must stay bound to localhost unless you intentionally harden and expose it.
DATABASE_URL=postgres://bussi:bussi@127.0.0.1:5432/bussi
FILE_STORAGE_DIR=.data/uploads
MAX_UPLOAD_BYTES=15728640
MAX_PARSE_PAGES=50

# Cloud embeddings only for v1. Schema is fixed to 1536 dimensions.
EMBEDDINGS_PROVIDER=openai
EMBEDDINGS_MODEL=text-embedding-3-small
OPENAI_API_KEY=

# Alternative provider. For OpenRouter, use OpenAI-compatible model IDs.
# EMBEDDINGS_PROVIDER=openrouter
# EMBEDDINGS_MODEL=nvidia/llama-nemotron-embed-vl-1b-v2:free
OPENROUTER_API_KEY=

# Default chat uses OpenRouter's free router. Requires OPENROUTER_API_KEY.
CHAT_PROVIDER=openrouter
CHAT_MODEL=openrouter/free
# CHAT_PROVIDER=openai
# CHAT_MODEL=gpt-5-mini

# Keep public demo closed unless you intentionally open registration.
ALLOW_SIGN_UP=false
